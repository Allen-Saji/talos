---
/* Layer cake — architecture diagram, hand-laid SVG. Mirrors docs/architecture.md. */
---

<figure class="tlx-cake">
  <svg viewBox="0 0 920 580" role="img" aria-labelledby="cake-title cake-desc" preserveAspectRatio="xMidYMin meet">
    <title id="cake-title">Talos architecture</title>
    <desc id="cake-desc">Three thin clients (CLI, Telegram, MCP hosts) connect to a single talosd daemon. The daemon contains channel adapters, the Vercel AI SDK runtime, KeeperHub middleware, PGLite persistence, a viem wallet, and a hot pool of MCP tool servers.</desc>

    <defs>
      <linearGradient id="bandRuntime" x1="0" x2="0" y1="0" y2="1">
        <stop offset="0" stop-color="#1a1a23"/>
        <stop offset="1" stop-color="#13131a"/>
      </linearGradient>
      <linearGradient id="bandKH" x1="0" x2="0" y1="0" y2="1">
        <stop offset="0" stop-color="#251a10"/>
        <stop offset="1" stop-color="#1c130a"/>
      </linearGradient>
      <linearGradient id="bandPersist" x1="0" x2="0" y1="0" y2="1">
        <stop offset="0" stop-color="#13131a"/>
        <stop offset="1" stop-color="#0e0e15"/>
      </linearGradient>
      <linearGradient id="bandWallet" x1="0" x2="0" y1="0" y2="1">
        <stop offset="0" stop-color="#0f0f15"/>
        <stop offset="1" stop-color="#0b0b10"/>
      </linearGradient>
      <linearGradient id="bandTools" x1="0" x2="0" y1="0" y2="1">
        <stop offset="0" stop-color="#13131a"/>
        <stop offset="1" stop-color="#0e0e14"/>
      </linearGradient>
      <marker id="arrow" viewBox="0 0 10 10" refX="9" refY="5" markerWidth="7" markerHeight="7" orient="auto-start-reverse">
        <path d="M0 0 L10 5 L0 10 z" fill="#b87333"/>
      </marker>
    </defs>

    <!-- Thin clients row -->
    <g class="cake-clients">
      <rect x="40" y="20" width="200" height="56" rx="6" fill="#13131a" stroke="#25252f"/>
      <text x="140" y="44" class="cake-h">talos repl</text>
      <text x="140" y="62" class="cake-s">CLI WS client</text>

      <rect x="360" y="20" width="200" height="56" rx="6" fill="#13131a" stroke="#25252f"/>
      <text x="460" y="44" class="cake-h">Telegram</text>
      <text x="460" y="62" class="cake-s">grammY long-poll</text>

      <rect x="680" y="20" width="200" height="56" rx="6" fill="#13131a" stroke="#25252f"/>
      <text x="780" y="44" class="cake-h">MCP hosts</text>
      <text x="780" y="62" class="cake-s">Claude Desktop · Cursor · OpenClaw</text>
    </g>

    <!-- arrows down -->
    <line x1="140" y1="80" x2="140" y2="118" stroke="#b87333" stroke-width="1.5" marker-end="url(#arrow)"/>
    <line x1="460" y1="80" x2="460" y2="118" stroke="#b87333" stroke-width="1.5" marker-end="url(#arrow)"/>
    <line x1="780" y1="80" x2="780" y2="118" stroke="#b87333" stroke-width="1.5" marker-end="url(#arrow)"/>

    <!-- Daemon container -->
    <rect x="40" y="124" width="840" height="328" rx="10" fill="#0d0d12" stroke="#34343f"/>
    <text x="60" y="148" class="cake-tag">talosd</text>
    <text x="100" y="148" class="cake-tag-sub">always-running daemon · launchd / systemd · WS 127.0.0.1:7711</text>

    <!-- Channel adapters band -->
    <rect x="60" y="164" width="800" height="44" rx="6" fill="url(#bandRuntime)" stroke="#25252f"/>
    <text x="76" y="190" class="cake-band-label">Channel adapters</text>
    <text x="220" y="190" class="cake-band-detail">cli-ws · telegram · mcp-server  ·  bearer-token auth</text>

    <!-- Runtime band -->
    <rect x="60" y="220" width="800" height="80" rx="6" fill="url(#bandRuntime)" stroke="#25252f"/>
    <text x="76" y="246" class="cake-band-label">Runtime</text>
    <text x="220" y="246" class="cake-band-detail">Vercel AI SDK v6  ·  streamText  ·  hot MCP host</text>
    <text x="220" y="268" class="cake-band-detail">Provider router · Agent registry · Memory mgr · Prompt builder</text>
    <text x="220" y="288" class="cake-band-detail">three-tier memory: hot 20 / warm summary / cold semantic recall ≥ 0.78</text>

    <!-- KH middleware band -->
    <rect x="60" y="312" width="800" height="44" rx="6" fill="url(#bandKH)" stroke="#3a2710"/>
    <text x="76" y="338" class="cake-band-label" fill="#d4925a">KeeperHub middleware</text>
    <text x="280" y="338" class="cake-band-detail">audit-by-default · annotation-driven routing · KNOWN_READONLY bypass</text>

    <!-- Persistence band -->
    <rect x="60" y="368" width="394" height="68" rx="6" fill="url(#bandPersist)" stroke="#25252f"/>
    <text x="76" y="394" class="cake-band-label">PGLite + Drizzle</text>
    <text x="76" y="416" class="cake-band-detail">knowledge · conversations</text>
    <text x="76" y="430" class="cake-band-detail-faint">pgvector HNSW · tsvector GIN · single file</text>

    <!-- Wallet + Cron band -->
    <rect x="466" y="368" width="394" height="68" rx="6" fill="url(#bandWallet)" stroke="#25252f"/>
    <text x="482" y="394" class="cake-band-label">Wallet + Cron</text>
    <text x="482" y="416" class="cake-band-detail">viem signer · BYOK · mode 0600</text>
    <text x="482" y="430" class="cake-band-detail-faint">nightly knowledge cron · L2Beat · DefiLlama · changelogs</text>

    <!-- arrow daemon -> tools -->
    <line x1="460" y1="452" x2="460" y2="486" stroke="#b87333" stroke-width="1.5" marker-end="url(#arrow)"/>

    <!-- Hot MCP tool servers -->
    <rect x="40" y="492" width="840" height="80" rx="10" fill="#0d0d12" stroke="#34343f"/>
    <text x="60" y="514" class="cake-tag">Hot MCP tool servers</text>
    <text x="220" y="514" class="cake-tag-sub">no respawn cost · namespaced · annotation-routed</text>

    <g class="cake-tools">
      <g class="cake-tool"><rect x="60" y="528" width="124" height="32" rx="6" fill="#181822" stroke="#25252f"/><text x="122" y="548" class="cake-pill">AgentKit</text></g>
      <g class="cake-tool"><rect x="194" y="528" width="124" height="32" rx="6" fill="#181822" stroke="#25252f"/><text x="256" y="548" class="cake-pill">Blockscout</text></g>
      <g class="cake-tool"><rect x="328" y="528" width="124" height="32" rx="6" fill="#181822" stroke="#25252f"/><text x="390" y="548" class="cake-pill">EVM-MCP</text></g>
      <g class="cake-tool"><rect x="462" y="528" width="124" height="32" rx="6" fill="#181822" stroke="#25252f"/><text x="524" y="548" class="cake-pill">Li.Fi</text></g>
      <g class="cake-tool"><rect x="596" y="528" width="124" height="32" rx="6" fill="#1f1812" stroke="#3a2710"/><text x="658" y="548" class="cake-pill" fill="#d4925a">Aave V3</text></g>
      <g class="cake-tool"><rect x="730" y="528" width="124" height="32" rx="6" fill="#1f1812" stroke="#3a2710"/><text x="792" y="548" class="cake-pill" fill="#d4925a">Uniswap V3</text></g>
    </g>
  </svg>
</figure>

<style>
  .tlx-cake {
    margin: 0;
    background: var(--tlx-bg-rise);
    border: 1px solid var(--tlx-border);
    border-radius: var(--tlx-radius-lg);
    padding: 1.5rem;
    overflow-x: auto;
  }
  .tlx-cake svg { width: 100%; height: auto; min-width: 720px; }
  @media (max-width: 720px) {
    .tlx-cake { padding: 1rem; }
    .tlx-cake svg { min-width: 720px; }
  }
  .cake-h { font-family: var(--sl-font); font-size: 14px; font-weight: 600; fill: var(--tlx-fg-strong); text-anchor: middle; }
  .cake-s { font-family: var(--sl-font); font-size: 11px; fill: var(--tlx-fg-muted); text-anchor: middle; }
  .cake-tag { font-family: var(--sl-font-mono); font-size: 11.5px; fill: var(--tlx-bronze); letter-spacing: 0.06em; }
  .cake-tag-sub { font-family: var(--sl-font); font-size: 11.5px; fill: var(--tlx-fg-muted); }
  .cake-band-label { font-family: var(--sl-font); font-size: 13px; font-weight: 600; fill: var(--tlx-fg-strong); }
  .cake-band-detail { font-family: var(--sl-font); font-size: 12px; fill: var(--tlx-fg); }
  .cake-band-detail-faint { font-family: var(--sl-font); font-size: 11.5px; fill: var(--tlx-fg-muted); }
  .cake-pill { font-family: var(--sl-font); font-size: 12.5px; font-weight: 500; fill: var(--tlx-fg-strong); text-anchor: middle; }
</style>
