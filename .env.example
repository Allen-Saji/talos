# OpenAI API key (BYOK — never commit a real key)
OPENAI_API_KEY=

# OpenAI-compatible base URL (default: https://api.openai.com/v1)
# Use for local models, proxies, or alternative providers (Together, Groq, etc.)
# OPENAI_BASE_URL=

# KeeperHub MCP endpoint
KEEPERHUB_URL=

# Telegram bot token (only if using TG channel)
# TELEGRAM_BOT_TOKEN=

# --- Optional overrides ---

# Override Talos data dir (default: $XDG_DATA_HOME/talos or ~/.local/share/talos)
# TALOS_DATA_DIR=

# Override Talos config dir (default: $XDG_CONFIG_HOME/talos or ~/.config/talos)
# TALOS_CONFIG_DIR=

# Daemon WS port (default: 7711)
# TALOS_DAEMON_PORT=7711

# Log level: debug | info | warn | error (default: info)
# TALOS_LOG_LEVEL=info
